<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Fragment>
    <!-- Sets the installer window title bar icon and Add/Remove Programs icon -->
    <Icon Id="AppCustomIcon" SourceFile="icon.ico" />
    <Property Id="ARPPRODUCTICON" Value="AppCustomIcon" />
  </Fragment>
</Wix>
